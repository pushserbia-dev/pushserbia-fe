{
  "version": 2,
  "public": true,
  "name": "pushserbia-fe",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/pushserbia-fe/**"
    }
  }
}
